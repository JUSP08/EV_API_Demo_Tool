{
  "name": "ev-api-tester",
  "version": "0.1.0",
  "description": "Desktop wrapper for the EV API Tester local dashboard.",
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.belimo.ev-api-tester",
    "productName": "EV API Tester",
    "files": [
      "electron/**/*",
      "index.html",
      "app.js",
      "styles.css",
      "server.py",
      "ev_api_tester.py"
    ],
    "extraResources": [
      "index.html",
      "app.js",
      "styles.css",
      "server.py",
      "ev_api_tester.py"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
